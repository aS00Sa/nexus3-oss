#!/bin/bash
# Обновление AllowedIPs пира по /etc/wireguard/<iface>.domains (правка вручную на хосте; деплой не трогает файл).
set -euo pipefail
IFACE="{{ nexus_wireguard_interface }}"
CONF="/etc/wireguard/${IFACE}.conf"
DOMAINS_FILE="/etc/wireguard/${IFACE}.domains"
PEER="$(grep -m1 '^PublicKey' "$CONF" | sed 's/^PublicKey *= *//;s/[[:space:]]*$//')"
if [ -z "$PEER" ]; then
  echo "nexus-wg-refresh: no PublicKey in $CONF" >&2
  exit 1
fi
STATIC_IPS=(
{% for cidr in nexus_wireguard_allowed_ips_static %}
  "{{ cidr }}"
{% endfor %}
)
collect_ips() {
  local out="" sep="" d
  for cidr in "${STATIC_IPS[@]}"; do
    [ -z "$cidr" ] && continue
    out="${out}${sep}${cidr}"
    sep=","
  done
  if [ ! -f "$DOMAINS_FILE" ]; then
    echo "$out"
    return 0
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    d="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [ -z "$d" ] && continue
    while read -r ip; do
      [ -z "$ip" ] && continue
      case "$ip" in
        *:*) suffix="/128" ;;
        *) suffix="/32" ;;
      esac
      out="${out}${sep}${ip}${suffix}"
      sep=","
    done < <(getent ahosts "$d" 2>/dev/null | awk '{print $1}' | sort -u)
  done < "$DOMAINS_FILE"
  echo "$out"
}
ALLOWED="$(collect_ips)"
if [ -z "$ALLOWED" ]; then
  echo "nexus-wg-refresh: nothing to apply (нет статики и нет резолва из $DOMAINS_FILE) — оставляем AllowedIPs из $CONF" >&2
  exit 0
fi
wg set "$IFACE" peer "$PEER" allowed-ips "$ALLOWED"
