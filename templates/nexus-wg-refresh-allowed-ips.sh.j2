#!/bin/bash
# AllowedIPs: списки в {{ nexus_wireguard_lists_dir }}/ (общие для wg / awg); .conf интерфейса — в STATE_DIR.
set -euo pipefail
IFACE="{{ nexus_wireguard_interface }}"
STATE_DIR="{{ nexus_wireguard_state_dir }}"
LISTS_DIR="{{ nexus_wireguard_lists_dir }}"
CLI="{{ nexus_wireguard_cli }}"
CONF="${STATE_DIR}/${IFACE}.conf"
STATIC_FILE="${LISTS_DIR}/{{ nexus_wireguard_lists_static_basename }}"
DOMAINS_FILE="${LISTS_DIR}/{{ nexus_wireguard_lists_domains_basename }}"
PEER="$(grep -m1 '^PublicKey' "$CONF" | sed 's/^PublicKey *= *//;s/[[:space:]]*$//')"
if [ -z "$PEER" ]; then
  echo "nexus-wg-refresh: no PublicKey in $CONF" >&2
  exit 1
fi
collect_ips() {
  local out="" sep="" d c
  if [ -f "$STATIC_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      c="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      [ -z "$c" ] && continue
      out="${out}${sep}${c}"
      sep=","
    done < "$STATIC_FILE"
  fi
  if [ ! -f "$DOMAINS_FILE" ]; then
    echo "$out"
    return 0
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    d="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [ -z "$d" ] && continue
    while read -r ip; do
      [ -z "$ip" ] && continue
      case "$ip" in
        *:*) suffix="/128" ;;
        *) suffix="/32" ;;
      esac
      out="${out}${sep}${ip}${suffix}"
      sep=","
    done < <(getent ahosts "$d" 2>/dev/null | awk '{print $1}' | sort -u)
  done < "$DOMAINS_FILE"
  echo "$out"
}
MAX_ENTRIES={{ nexus_wireguard_refresh_allowedips_max_entries | int }}
ALLOWED_RAW="$(collect_ips)"
if [ -z "$ALLOWED_RAW" ]; then
  echo "nexus-wg-refresh: nothing to apply (пусто $STATIC_FILE и нет резолва из $DOMAINS_FILE) — оставляем AllowedIPs из $CONF" >&2
  exit 0
fi
# Глобальный дедуп префиксов (один IP мог прийти из нескольких FQDN). Слишком длинный список → netlink ENOSPC, часто как «No space left on device» при нормальном df.
ALLOWED=$(printf '%s' "$ALLOWED_RAW" | tr ',' '\n' | sed '/^[[:space:]]*$/d' | sort -u)
if [ "${MAX_ENTRIES}" -gt 0 ]; then
  cnt=$(printf '%s\n' "$ALLOWED" | sed '/^$/d' | wc -l | tr -d '[:space:]')
  if [ "${cnt:-0}" -gt "$MAX_ENTRIES" ]; then
    echo "nexus-wg-refresh: предупреждение — префиксов ${cnt}, оставляю первые ${MAX_ENTRIES} (nexus_wireguard_refresh_allowedips_max_entries)" >&2
    ALLOWED=$(printf '%s\n' "$ALLOWED" | head -n "$MAX_ENTRIES")
  fi
fi
ALLOWED=$(printf '%s\n' "$ALLOWED" | paste -sd, -)
if [ -z "$ALLOWED" ]; then
  echo "nexus-wg-refresh: после дедупа список пуст" >&2
  exit 0
fi
"${CLI}" set "$IFACE" peer "$PEER" allowed-ips "$ALLOWED"
