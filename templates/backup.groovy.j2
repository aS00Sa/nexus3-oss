import java.time.LocalDateTime
import org.apache.commons.io.FileUtils
import java.time.format.DateTimeFormatter
import org.sonatype.nexus.scheduling.TaskConfiguration
import org.sonatype.nexus.scheduling.TaskScheduler
import org.sonatype.nexus.scheduling.TaskInfo
import org.sonatype.nexus.scheduling.schedule.Schedule
import java.util.concurrent.TimeUnit
import java.nio.file.Path
import java.nio.file.Paths


/**
 * This groovy script is meant to be included in a schedulled task in nexus.
 * It will perform a full backup of your installation with the following steps.
 * 1- If <nexusBackupRotate> and <nexusBackupRotateFirst> are true, pre-rotate backup dirs keeping last <nexusBackupKeepRotations-1> backups (making room for current backup)
 * 2- Create a temporary nexus db-backup task to store db backup in <nexusBackupDirPath>/blob-backup-<YY-MM-dd>/db
 * 3- Start running the temporary task
 * 4- Copy all blobstores from <nexusDataDirPath>/blobs to <nexusBackupDirPath>/blob-backup-<YY-MM-dd>
 * 5- Eventually wait for the nexus temporary db-backup task to complete
 * 6- Delete the nexus temporary db-backup task
 * 7- If <nexusBackupRotate> is true and <nexusBackupRotateFirst> is false, post-rotate backup dirs keeping last <nexusBackupKeepRotations> backups
 */

nexusBackupDirPath = "{{ nexus_backup_dir }}"
nexusDataDirPath = "{{ nexus_data_dir }}"
nexusBackupRotate = Boolean.valueOf("{{ nexus_backup_rotate }}")
nexusBackupRotateFirst = Boolean.valueOf("{{ nexus_backup_rotate_first }}")
nexusBackupKeepRotations = "{{ nexus_backup_keep_rotations }}".toInteger()

backupDateString = LocalDateTime.now().format(DateTimeFormatter.ofPattern('yyyy-MM-dd-HH-mm-ss'))
CurrentBackupDirPath = nexusBackupDirPath+'/blob-backup-'+backupDateString

/** Nexus H2 backup task expects a path relative to the data directory (not an absolute path). */
Path dataRoot = Paths.get(nexusDataDirPath).toAbsolutePath().normalize()
Path dbDir = Paths.get(CurrentBackupDirPath, "db").toAbsolutePath().normalize()
String dbBackupLocation
try {
    dbBackupLocation = dataRoot.relativize(dbDir).toString().replace('\\', '/')
} catch (IllegalArgumentException e) {
    dbBackupLocation = dbDir.toString()
    log.warn("Could not relativize DB backup path to data dir ({}), using absolute path — H2 task may reject this: {}", nexusDataDirPath, dbBackupLocation)
}
log.info("Embedded DB backup location for built-in task: {}", dbBackupLocation)

/** Helper function to rotate backups */
def rotateBackup() {
    if (nexusBackupRotateFirst) {
        realKeep = nexusBackupKeepRotations - 1
        rotateMsg = "Pre-rotating"
    } else {
        realKeep = nexusBackupKeepRotations
        rotateMsg = "Post-rotating"
    }

    log.info("{} backups to keep only last {} backups", rotateMsg, nexusBackupKeepRotations.toString())
    backupDirs = []
    backupCounter = 0
    backupPattern = ~/blob-backup-.*/
    new File(nexusBackupDirPath).eachDirMatch(backupPattern) { dir ->
        backupDirs << dir
    }
    backupDirs.sort{ it.name }.reverse().each { dir ->
        backupCounter++
        if (backupCounter > realKeep) {
            log.info("Deleting backup {}", dir.name.toString())
            dir.deleteDir()
        }
    }
    if (backupCounter > realKeep) {
        backupDeleted =  backupCounter - realKeep
        log.info("Deleted a total of {} backup directories", backupDeleted)
    } else {
        log.info("There were no backup directories to delete")
    }
}

try {
    log.info("Backup directory is {}", CurrentBackupDirPath)

    /** pre backup rotation */
    if (nexusBackupRotate && nexusBackupRotateFirst) {
        rotateBackup()
    }

    log.info("Create a temporary task to backup nexus db at {} (under {})", dbBackupLocation, CurrentBackupDirPath)
    TaskScheduler taskScheduler = container.lookup(TaskScheduler.class.getName())
    List<String> candidateTaskTypeIds = [
        '{{ nexus_backup_db_task_type_id }}',
        'db.backup',
        'h2.backup',
        'database.backup'
    ].findAll { it != null && it.toString().trim().length() > 0 }.collect { it.toString().trim() }.unique()

    TaskConfiguration tempBackupTaskConfiguration = null
    String resolvedDbTaskTypeId = null
    for (String candidateTypeId : candidateTaskTypeIds) {
        try {
            tempBackupTaskConfiguration = taskScheduler.createTaskConfigurationInstance(candidateTypeId)
            resolvedDbTaskTypeId = candidateTypeId
            break
        } catch (IllegalArgumentException ignored) {
            log.debug("Task type-id {} is not available in this Nexus version", candidateTypeId)
        }
    }
    TaskInfo tempBackupTask = null
    if (tempBackupTaskConfiguration == null) {
        if (Boolean.valueOf("{{ nexus_backup_allow_blob_only_fallback | default(true) }}")) {
            log.warn("Could not find supported DB backup task type-id (tried: {}). Continue with blob-only backup. "
                + "Set nexus_backup_db_task_type_id to a valid type-id or disable fallback with "
                + "nexus_backup_allow_blob_only_fallback=false to fail hard.", candidateTaskTypeIds.join(', '))
        } else {
            throw new Exception("Could not find supported DB backup task type-id. Tried: " + candidateTaskTypeIds.join(', ')
                + ". Set nexus_backup_db_task_type_id in vars to the actual type-id from this Nexus instance.")
        }
    } else {
        log.info("Using DB backup task type-id: {}", resolvedDbTaskTypeId)
        tempBackupTaskConfiguration.setName('Temporary db.backup task')
        tempBackupTaskConfiguration.setString('location', dbBackupLocation)
        Schedule schedule = taskScheduler.scheduleFactory.manual()
        tempBackupTask = taskScheduler.scheduleTask(tempBackupTaskConfiguration, schedule)

        log.info("Run the temporary db backup task")
        tempBackupTask.runNow()
    }

    log.info("Copy the blobstores into {}", CurrentBackupDirPath)
    FileUtils.copyDirectory(new File(nexusDataDirPath+'/blobs'), new File(CurrentBackupDirPath))

    if (tempBackupTask != null) {
        log.info("Wait for temporary db backup task to finish")
        int waitSeconds = 0
        final int maxWaitSeconds = 7200
        String stateStr
        while ((stateStr = tempBackupTask.currentState.getState().toString()) != "WAITING") {
            if (stateStr == "FAILED" || stateStr == "CANCELED") {
                throw new Exception("Temporary db.backup task ended with state: " + stateStr)
            }
            if (waitSeconds >= maxWaitSeconds) {
                throw new Exception("Temporary db.backup task did not reach WAITING within " + maxWaitSeconds + "s (last state: " + stateStr + ")")
            }
            TimeUnit.SECONDS.sleep(1)
            waitSeconds++
        }
        log.info("Remove temporary task")
        tempBackupTask.remove()
    } else {
        log.warn("DB backup step skipped because no supported DB backup task type-id is available.")
    }

    /** Post backup rotation */
    if (nexusBackupRotate && !nexusBackupRotateFirst) {
        rotateBackup()
    }

} catch (Exception e) {
    log.error("Nexus backup script failed", e)
    throw e
}
